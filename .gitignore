.encore
encore.gen.go
encore.gen.cue
/.encore
node_modules
/encore.gen

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# ...but frontend/.env is tracked: it holds ONLY the public Google Web Client ID,
# which is needed at build time (can't be runtime-derived) and ships in the bundle
# anyway. Real secrets still live in the gitignored .env.local / .env.production.
!/frontend/.env

# Encore local secret overrides (never commit real secret values)
.secrets.local.cue

# OS / editor cruft
.DS_Store

# Tooling & log artifacts
.playwright-mcp/
*.log
*.tsbuildinfo

# Stray local build output (canonical build output is backend/frontend/dist,
# produced by `cd backend && bun run build`)
/frontend/dist/
