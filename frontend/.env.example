# Google Sign-In (public OAuth 2.0 Web Client ID). When unset, the "Sign in with
# Google" button is hidden and only email/password auth is available. This exact
# value must also be set as the backend `GoogleClientID` secret (byte-identical, or
# the ID-token audience check fails). No client secret is used.
VITE_GOOGLE_CLIENT_ID=

# API Configuration
VITE_API_URL=https://your-vercel-domain.vercel.app
