# Tracked, committed on purpose (see the negation rule in the repo-root .gitignore).
#
# This holds ONLY the public Google OAuth 2.0 Web Client ID. It is NOT a secret:
# it is embedded in the shipped JS bundle regardless, and no client secret lives
# here. It must be present at BUILD time (Vite inlines import.meta.env.* at build),
# and it cannot be derived at runtime the way the backend URL is
# (see frontend/lib/backendUrl.ts), so it has to be committed to reach Encore Cloud
# builds for staging and production.
#
# This value MUST stay byte-identical to the backend `GoogleClientID` secret, and
# every deployed frontend origin must be listed as an Authorized JavaScript origin
# on this client in Google Cloud Console — otherwise the ID-token audience check
# fails or the button silently no-ops.
#
# Local dev overrides: put a different id in the gitignored frontend/.env.local.
VITE_GOOGLE_CLIENT_ID=559209556175-gbd6hrs4fjvoeiqa9p4cvkdq4na9aq7n.apps.googleusercontent.com
